{
  "name": "skymp-launcher",
  "version": "1.1.1",
  "description": "Customizable launcher template for SkyMP multiplayer servers",
  "main": "src/main.js",
  "author": "F02K",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "test": "node --test",
    "validate:config": "node scripts/validate-config.js",
    "validate:release": "node scripts/validate-config.js --release",
    "build": "npm run validate:config && electron-builder --config electron-builder.config.js",
    "build:win": "npm run validate:config && electron-builder --config electron-builder.config.js --win",
    "build:linux": "npm run validate:config && electron-builder --config electron-builder.config.js --linux",
    "build:mac": "npm run validate:config && electron-builder --config electron-builder.config.js --mac"
  },
  "dependencies": {
    "adm-zip":        "^0.5.10",
    "classic-level":  "^1.4.1",
    "dotenv":         "^16.4.5",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "electron":         "^41.2.0",
    "electron-builder": "^26.8.1"
  }
}
