# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the SkyMP launcher backend server.
# The launcher fetches the server list, modlist, news, and client files from here.
# Development override only. Release builds use launcher.config.json unless the
# packaged process is started with an explicit API_URL environment variable.
API_URL=https://api.frostfall.online
